# Variables de entorno de B3S Leads.
# Copia a .env.local (local) y configúralas en el hosting (Netlify → Site
# settings → Environment variables). NUNCA commitear .env.local.
# Las NEXT_PUBLIC_* se incrustan en el BUILD: si las cambias, hay que volver
# a desplegar para que surtan efecto.

# --- Supabase (OBLIGATORIAS) ---
# Settings → API. La URL y la anon key son públicas; la service_role es SECRETA.
NEXT_PUBLIC_SUPABASE_URL=https://xhmajauvtqxvxmecjyxl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # solo servidor, nunca en cliente

# --- Config del sistema (opcionales; hay valores por defecto en el código) ---
CLAUDE_MODEL=claude-sonnet-4-6
CREDIT_BUDGET_MONTHLY=100
SCAN_MAX_PER_NIGHT=10
SCANNER_SCORE_THRESHOLD=60     # score Brand3 >= umbral → marca resuelta

# --- Integraciones (opcionales; la app funciona sin ellas) ---
ANTHROPIC_API_KEY=             # console.anthropic.com. Vacío = sin redacción IA.
BRAND3_SCANNER_API_TOKEN=      # solo para LANZAR scans nuevos (secreto de Jesús). Importar scans existentes NO lo necesita.
