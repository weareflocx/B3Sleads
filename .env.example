# FLOC* Radar — variables de entorno
# Copia a .env.local y rellena. NUNCA commitear .env.local.

BRAND3_SCANNER_API_TOKEN=      # secreto compartido del servidor Brand3 (Fly.io secrets), lo tiene Jesús/GsusFC. Mín 24 chars. No está en web ni repo.
ANTHROPIC_API_KEY=             # console.anthropic.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # solo para el pipeline, nunca en cliente

CREDIT_BUDGET_MONTHLY=100
SCAN_MAX_PER_NIGHT=10
SCANNER_SCORE_THRESHOLD=60     # score Brand3 >= umbral → marca resuelta → descartar
CLAUDE_MODEL=claude-sonnet-4-6
